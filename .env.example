# LLM provider (any OpenAI-compatible)
# Gemini:         LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/  LLM_MODEL=gemini-2.5-flash
# OpenAI:         LLM_BASE_URL=https://api.openai.com/v1                                LLM_MODEL=gpt-4o
# GreenNode AIP:  LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1       LLM_MODEL=qwen/qwen3-5-27b
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# === OPTIONAL ===
# GreenNode IAM credentials
GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=

# oss-advisor adapter keys (for enhanced analysis)
# GitHub token raises rate limit 60 → 5000 req/hr
GITHUB_TOKEN=
LIBRARIESIO_KEY=
SNYK_KEY=
SOCKET_KEY=
