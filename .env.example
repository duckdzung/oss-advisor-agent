# GreenNode IAM credentials
GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=

# LLM provider (any OpenAI-compatible)
# GreenNode AIP: LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
# OpenAI:        LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Path to oss-advisor directory (local dev override; container sets this via Dockerfile)
OSS_ADVISOR_DIR=../oss-advisor

# Optional: oss-advisor adapter keys (injected at container startup via docker-entrypoint.sh)
# GitHub token raises rate limit 60 → 5000 req/hr and enables health/bus-factor signals
GITHUB_TOKEN=
LIBRARIESIO_KEY=
SNYK_KEY=
SOCKET_KEY=
